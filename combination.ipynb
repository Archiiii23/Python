   ],
   "source": [
    "def factorial(n):\n",
    "    f = 1\n",
    "    for i in range(1, n + 1):\n",
    "        f *= i\n",
    "    return f\n",
    "\n",
    "def nCr(n, r):\n",
    "    return factorial(n) // (factorial(r) * factorial(n - r))\n",
    "\n",
    "# Input\n",
    "n = int(input(\"Enter n: \"))\n",
    "r = int(input(\"Enter r: \"))\n",
    "\n",
    "# Output\n",
    "print(\"nCr =\", nCr(n, r))"
   ]
  }
 ],
