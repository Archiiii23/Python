   ],
   "source": [
    "num=int (input(\"ENTER THE NUMBER:\" ))\n",
    "if num > 1:\n",
    "  for i in range (2, int (num**0.5)+1):\n",
    "   if num % i ==0:\n",
    "      print(num,\"NOT A PRIME NO.\")\n",
    "      break\n",
    "  else:\n",
    "      print(num,\"PRIME\")\n",
    "else:\n",
    "      print(num,\"NOT A PRIME NO.\")\n",
    "\n"
   ]
  }
