    "n=int (input(\"ENTER THE NUMBER:\" ))\n",
    "i=1\n",
    "while(i<=n):\n",
    " if(n%i==0 and i%2==0):\n",
    "   print(i,\"IS EVEN\")\n",
    " elif(n%i==0 and i%2!=0):\n",
    "   print(i,\" IS ODD\")\n",
    " i+=1 \n"
   ]
  }
